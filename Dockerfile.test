FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive
ENV container_test=true

# Install ansible as root so it lands in /usr/local/bin (no PATH juggling)
RUN apt-get update && apt-get install -y \
    sudo curl git python3 python3-pip \
    && pip3 install --break-system-packages ansible \
    && rm -rf /var/lib/apt/lists/*

# Non-root user with passwordless sudo (mirrors a real workstation)
RUN useradd -m -s /bin/bash dev \
    && echo "dev ALL=(ALL) NOPASSWD:ALL" >> /etc/sudoers

USER dev
WORKDIR /home/dev

COPY --chown=dev:dev . /home/dev/dotfiles-ansible
WORKDIR /home/dev/dotfiles-ansible

RUN ansible-galaxy collection install -r requirements.yml

CMD ["ansible-playbook", "playbook.yml", \
     "--skip-tags", "skip_in_container", \
     "--extra-vars", "container_test=true", \
     "-v"]
